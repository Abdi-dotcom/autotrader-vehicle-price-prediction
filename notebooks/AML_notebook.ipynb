#10.Clustering for Feature Engineering

##10.1.Apply KMeans on processed features

# sample for clustering
n_sample = 10000
rng = np.random.RandomState(42)
idx = rng.choice(X_train_fs.shape[0], size=n_sample, replace=False)

X_cluster_sample = X_train_fs[idx]

# fits KMeans
kmeans = KMeans(n_clusters=8, random_state=42, n_init=10)
kmeans.fit(X_cluster_sample)

# assigns clusters
train_clusters = kmeans.predict(X_train_fs)
val_clusters   = kmeans.predict(X_val_fs)
test_clusters  = kmeans.predict(X_test_fs)

##10.2.Add cluster as new feature

# reshapes
train_clusters = train_clusters.reshape(-1, 1)
val_clusters   = val_clusters.reshape(-1, 1)
test_clusters  = test_clusters.reshape(-1, 1)

# one-hot encoding
ohe = OneHotEncoder(sparse_output=False, handle_unknown='ignore')

train_ohe = ohe.fit_transform(train_clusters)
val_ohe   = ohe.transform(val_clusters)
test_ohe  = ohe.transform(test_clusters)

# combines with original features
X_train_cluster = np.hstack([X_train_fs, train_ohe])
X_val_cluster   = np.hstack([X_val_fs, val_ohe])
X_test_cluster  = np.hstack([X_test_fs, test_ohe])

print("New feature shape:", X_train_cluster.shape)

##10.3.Train model with cluster feature

# lighter RF for speed
rf_cluster = RandomForestRegressor(
    n_estimators=100,
    max_depth=20,
    n_jobs=-1,
    random_state=42
)

# sample training for extra speed
n_sample = 50000
idx = np.random.choice(X_train_cluster.shape[0], n_sample, replace=False)

X_train_small = X_train_cluster[idx]
y_train_small = y_train.iloc[idx]

print("Training RF with cluster feature...")
rf_cluster.fit(X_train_small, y_train_small)

# evaluate
val_pred = rf_cluster.predict(X_val_cluster)
test_pred = rf_cluster.predict(X_test_cluster)

cluster_results = {
    "Model": "RF + Cluster Feature",
    "Val_MAE": mean_absolute_error(y_val, val_pred),
    "Test_MAE": mean_absolute_error(y_test, test_pred),
    "Test_R2": r2_score(y_test, test_pred)
}

cluster_df = pd.DataFrame([cluster_results])
display(cluster_df.round(2))

##10.4.Compare with previous models

comparison = pd.concat([comparison, cluster_df], ignore_index=True)

display(comparison[["Model", "Test_MAE", "Test_R2"]].round(2))

plt.figure(figsize=(8,5))
plt.hist(train_clusters, bins=8)
plt.title("Cluster Distribution (Training Set)")
plt.xlabel("Cluster")
plt.ylabel("Count")
plt.show()


