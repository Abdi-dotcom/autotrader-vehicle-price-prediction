    "SFM(ExtraTrees)": (X_train_fs, X_val_fs, X_test_fs),   # SelectFromModel using ExtraTrees
    "RFECV(Ridge)":    (X_train_rfe, X_val_rfe, X_test_rfe) # RFECV feature selection using Ridge
}
#function to evaluate the same model, across diffrent feature selection views
def compare_on_views(model, label):
    rows = []                         # Stores evaluation results for each view
    for view_name, (Xt, Xv, Xte) in views.items(): # Iterates over each feature selection method
        res, _ = fit_eval(model, Xt, y_train, Xv, y_val, Xte, y_test, f"{label} | {view_name}")  # Train and evaluate the model on the current feature set
        rows.append(res)
    return pd.DataFrame(rows).round(4)
# Random Forest comparison
