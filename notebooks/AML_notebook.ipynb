##5.3.Permutation Importance (validation, subsampled)

# Safe permutation importance implementation
def safe_permutation_importance(model, X, y, n_repeats=5, random_state=42):
    rng = np.random.RandomState(random_state)   # Random number generator for reproducibility

    # Baseline performance (no shuffle)
    baseline_pred = model.predict(X)   # Original predictions
    baseline_mae = mean_absolute_error(y, baseline_pred)  # Baseline MAE

    # Storage for importance values, Shape: (n_features, n_repeats)

    importances = np.zeros((X.shape[1], n_repeats))

    # Permutation loop over features
    for feature_idx in range(X.shape[1]):
        X_perm = X.copy()  # Copies to avoid altering original data
        for r in range(n_repeats):

            shuffled = X_perm[:, feature_idx].copy()   # Shuffles the selected feature column onl
            rng.shuffle(shuffled)
            X_perm[:, feature_idx] = shuffled

            # Evaluates model on permuted data
            perm_pred = model.predict(X_perm)
            perm_mae = mean_absolute_error(y, perm_pred)
             # Importance = degradation in performan
            importances[feature_idx, r] = perm_mae - baseline_mae


    importances_mean = importances.mean(axis=1)
    importances_std  = importances.std(axis=1)

    return importances_mean, importances_std

