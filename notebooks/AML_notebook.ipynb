perm_df = pd.DataFrame({
    "feature": feat_names,
    "importance_mean": pi_mean,
    "importance_std": pi_std
}).sort_values("importance_mean", ascending=False)

perm_df.head(10)

#6.SHAP/PDP Model Explanations

##6.1.SHAP + PDP

top_features_list = top_features['Feature'].tolist()
print("Top features for SHAP/PDP:", top_features_list)

# Sample rows to speed up computation (smaller than 300)
shap_sample_size = min(150, X_test_fs.shape[0])
rng = np.random.RandomState(42)
shap_idx = rng.choice(X_test_fs.shape[0], size=shap_sample_size, replace=False)

X_shap = X_test_fs[shap_idx]
y_shap = y_test.iloc[shap_idx]

##6.2.SHAP TreeExplainer

#creates a SHAP TreeExplainer for the final selected model
# tree_path_dependent: uses the tree structure for exact SHAP values
# model_output="raw": explains predictions in the model's native output space

explainer = shap.TreeExplainer(winner, feature_perturbation="tree_path_dependent", model_output="raw")
shap_values = explainer.shap_values(X_shap, approximate=True)


shap.summary_plot(
    shap_values,
    X_shap,
    feature_names=feat_names,
    max_display=5,  # shows only top 5 features
    show=True
)

##6.3.Partial Dependence Plots (PDP)

for feature in top_features_list[:2]:  # Partial Dependence Plots for top features
    PartialDependenceDisplay.from_estimator(
        winner,  # Trained final (winning) model
        X_shap,  # Dataset used for interpretation
        [feature],
        feature_names=feat_names,
        kind='average',
        grid_resolution=20
    )
    plt.show()  # Shows the average marginal effect of the feature on predictions

