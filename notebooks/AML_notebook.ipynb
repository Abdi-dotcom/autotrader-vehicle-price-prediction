##4.2.Weighted Averaging (learn weights on validation)

# this code learn weights (weight_rf, weight_gb) to minimise validation MAE
# small grid over weights to minimize validation MAE
weights = np.linspace(0.0, 1.0, 21)
best_weight, best_mae = None, np.inf

for w in weights:
    val_ensemble = w * rf_validation + (1 - w) * gb_validation
    mae = mean_absolute_error(y_val, val_ensemble)
    if mae < best_mae:
        best_mae = mae
        best_weight = w
# applied the best weight on test
test_ensemble = best_weight * rf_test + (1 - best_weight) * gb_test

weight_avg_results = {
  'Model': f'Weighted Avg (w_rf={best_weight:.2f}, w_gb={1-best_weight:.2f})',
    'Val_MAE': mean_absolute_error(y_val, best_weight * rf_validation + (1 - best_weight) * gb_validation),
    'Test_MAE': mean_absolute_error(y_test, test_ensemble),
    'Test_R2': r2_score(y_test, test_ensemble)

}
pd.DataFrame([weight_avg_results])

##4.3.Stacking Regressor (RF + HGBR → meta-learner/model)

**Note:**why rebuilding estimators, why ridge is used and why stacking work this way?
Thre rules for stacking:
1.   Base models must be recreated(cloneable), because stackingegressor needs fresh, unifitted models, not fitted ones. It clones the model and fits automatically
2.   Base models must be simple enough to clone
3.   Meta‑learner must be a simple, stable model









# Rebuild lighter base estimators ONLY for stacking (keeps it fast)
rf_params = (rf_best.get_params() if 'rf_best' in globals() else rf_base_fitted.get_params())
rf_est = RandomForestRegressor(
    n_estimators=min(80, rf_params.get('n_estimators', 100)),
    max_depth=min(12, rf_params.get('max_depth', 12)) if rf_params.get('max_depth', None) else 12,
    max_features=rf_params.get('max_features', 'sqrt'),
    min_samples_leaf=rf_params.get('min_samples_leaf', 1),
    n_jobs=-1,
    random_state=42
)

if 'gb_best' in globals() and gb_best.__class__.__name__ == "HistGradientBoostingRegressor":
    gb_params = gb_best.get_params()
    gb_est = HistGradientBoostingRegressor(
        max_iter=min(100, gb_params.get('max_iter', 100)),
        learning_rate=gb_params.get('learning_rate', 0.1),
        max_depth=gb_params.get('max_depth', None),
        early_stopping=True,
        validation_fraction=0.1,
        random_state=42
    )
else:
    # fallback to classic GB if that’s what you tuned
    base_gb = gb_best if 'gb_best' in globals() else gb_base_fitted
    gbp = base_gb.get_params()
    gb_est = GradientBoostingRegressor(
        n_estimators=min(120, gbp.get('n_estimators', 100)),
        learning_rate=gbp.get('learning_rate', 0.1),
        max_depth=min(4, gbp.get('max_depth', 3)),
        subsample=gbp.get('subsample', 1.0),
        random_state=42
    )

stack_fast = StackingRegressor(
    estimators=[('rf', rf_est), ('gb', gb_est)],
    final_estimator=Ridge(alpha=1.0),
