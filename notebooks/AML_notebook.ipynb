# Model fitting & evaluation function
def fit_eval(model, X_train, y_train, X_val, y_val, X_test, y_test, name):
    model.fit(X_train, y_train)    # Fits the model on the training data
    val_pred = model.predict(X_val)     # Predicts on validation and test sets
    test_pred = model.predict(X_test)
# Returns evaluation metrics and the fitted model
    return {
        'Model': name,
        'Val_MAE': mean_absolute_error(y_val, val_pred),
        'Test_MAE': mean_absolute_error(y_test, test_pred),
        'Test_R2': r2_score(y_test, test_pred)
    }, model


# Store baseline results
results_base = []

